[Unit]
Description=EverClaw XMTP Agent Chat Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{INSTALL_USER}}
WorkingDirectory={{EVERCLAW_PATH}}
ExecStart={{NODE_BIN}} {{EVERCLAW_PATH}}/skills/agent-chat/daemon.mjs
Restart=on-failure
RestartSec=10
Environment=NODE_ENV=production

StandardOutput=journal
StandardError=journal
SyslogIdentifier=everclaw-agent-chat

[Install]
WantedBy=multi-user.target
